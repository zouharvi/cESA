e9\u30f3\u30c9\u30d6\u30ec\u30f3\u30c9\u306e\u30dc\u30c8\u30eb\u4ee5\u5916\u3067\u552f\u4e00\u5165\u624b\u3067\u304d\u305f\u30e9\u30e0\u3067\u3057\u305f\u3002\u3053\u306e\u30e9\u30e0\u306e\u30a6\u30a7\u30d6\u30b5\u30a4\u30c8\u306f\u3053\u3061\u3089\u3067\u3059\uff08\u7ffb\u8a33\u6e08\u307f\uff09https://onerum-jp.translate.goog/produ... \u539f\u6587\uff1ahttps://onerum.jp/product/ie-island-ru... \u305c\u3072\u300cAbout\u300d\u30da\u30fc\u30b8\u3082\u3054\u89a7\u304f\u3060\u3055\u3044\u3002", "Gemini-2.5-Pro": "2/3 \\n \u3053\u306e\u4f0a\u6c5f\u5cf6 #rum \u306f\u30b7\u30f3\u30b0\u30eb\u30a2\u30a4\u30e9\u30f3\u30c9\u30b7\u30ea\u30fc\u30ba\u306e\u4e00\u672c\u3002#Naha #Okinawa \u3067\u306e\u77ed\u3059\u304e\u308b\u6ede\u5728\uff084\u5206\u306e3\u65e5\uff01\uff09\u3067\u306f\u3001\u5168\u5cf6\u30d6\u30ec\u30f3\u30c9\u306e\u30dc\u30c8\u30eb\u4ee5\u5916\u3067\u624b\u306b\u5165\u308c\u3089\u308c\u305f\u306e\u306f\u3053\u308c\u3060\u3051\u3060\u3063\u305f\u3002 \\n \u3053\u306e\u30e9\u30e0\u306b\u95a2\u3059\u308b\u30a6\u30a7\u30d6\u30da\u30fc\u30b8\u306f\u3053\u3061\u3089\uff08\u7ffb\u8a33\u7248\uff09 \\n https://onerum-jp.translate.goog/produ... \\n \u539f\u6587\uff1a https://onerum.jp/product/ie-island-ru... \\n \u300c\u79c1\u305f\u3061\u306b\u3064\u3044\u3066\u300d\u306e\u30da\u30fc\u30b8\u3082\u305c\u3072\u898b\u3066\u307f\u3066\u3002"}, "item_id": "en-ja_JP_#_social_#_112502991207286008_#_s3_#_dup0"}, {"src": "<img style=\"width: 100%;\" src=\"https://vilda.net/t/wmt25/assets/en/social/112502991207286008-anon/112502991207286008-anon_5.png\">", "src_text": "3/3 \\n Ok so I did make that #Daiquiri \\n 2 oz #rum \\n 1 oz fresh squeezed lime juice [wish I had shikuwasa] \\n \u00be oz rich simple syrup \\n Oh dear f$expletive deleted me - in a well chilled coupe, took a sip and this is exquisite. Close my eyes and aware of the back of my neck calming. \\n Didn't expect that. 180\u2070 from a more upfront sugary rum.", "tgt": {"CommandA-MT": "3/3 \\n \u3055\u3066\u3001#\u30c0